PORT=3000

# GitHub token with issues:write scope on genspec-dev/quality-gates (REQUIRED for gate submissions)
GITHUB_TOKEN=ghp_your_token_here

GATES_REGISTRY_URL=https://raw.githubusercontent.com/jghiringhelli/quality-gates/master/index.json
TAXONOMY_PATH=./taxonomy.json

# Admin key for GET /quarantine endpoint
ADMIN_KEY=your_admin_key_here

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/forgecraft

# Clerk (get from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe (get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAMS=price_...

# App URL for Stripe redirects
APP_URL=https://forgecraft.tools
