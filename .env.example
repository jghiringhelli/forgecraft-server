PORT=3000

# GitHub token with issues:write scope on genspec-dev/quality-gates (REQUIRED for gate submissions)
# Without this, POST /contribute/gate returns 503.
GITHUB_TOKEN=ghp_your_token_here

GATES_REGISTRY_URL=https://raw.githubusercontent.com/jghiringhelli/quality-gates/master/index.json
TAXONOMY_PATH=./taxonomy.json

# Admin key for GET /quarantine endpoint
ADMIN_KEY=your_admin_key_here

# Future:
# CLERK_SECRET_KEY=
# STRIPE_SECRET_KEY=
